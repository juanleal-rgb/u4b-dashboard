# U4B Dashboard — Environment Variables
# Copy this file to .env.local for local development

# PostgreSQL connection string (required)
# Railway provides this automatically via DATABASE_URL
DATABASE_URL=postgresql://user:password@host:5432/database

# Dashboard password (optional)
# If set, users must enter this password to access the dashboard
DASHBOARD_PASSWORD=

# Filter calls by start date (optional)
# Only show data created after this date
# Format: ISO 8601 (e.g., "2026-01-01T00:00:00.000Z")
RUNS_START_DATE=

# Webhook secret (optional)
# If set, incoming webhook requests must include this as:
#   Authorization: Bearer <secret>
#   OR x-webhook-secret: <secret>
WEBHOOK_SECRET=
